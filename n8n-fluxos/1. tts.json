    {
      "parameters": {
        "jsCode": "const child_process = require('child_process');\n\ntry {\n  const base64Data = items[0].json.audioContent;\n  if (!base64Data) throw new Error(\"Campo audioContent vazio\");\n\n  const buffer = Buffer.from(base64Data, 'base64');\n\n  // Adicionamos '-f mp3' para ele não ter dúvida do formato\n  // E usamos o flag '-i pipe:0' com o buffer\n  const result = child_process.spawnSync('ffmpeg', ['-f', 'mp3', '-i', 'pipe:0', '-f', 'null', '-'], {\n    input: buffer,\n  });\n\n  const output = result.stderr.toString();\n\n  // O FFmpeg gera várias linhas de \"time=\", precisamos da ÚLTIMA\n  const matches = [...output.matchAll(/time=(\\d{2}:\\d{2}:\\d{2}\\.\\d+)/g)];\n  \n  if (matches.length > 0) {\n    const lastMatch = matches[matches.length - 1][1];\n    const timeParts = lastMatch.split(':');\n    const seconds = (+timeParts[0]) * 3600 + (+timeParts[1]) * 60 + (+timeParts[2]);\n    \n    return [{\n      json: {\n        duracao: parseFloat(seconds.toFixed(3)),\n        duracao_formatada: lastMatch,\n        tamanho_kb: (buffer.length / 1024).toFixed(2),\n        status: \"Sucesso\"\n      }\n    }];\n  }\n\n  return [{\n    json: {\n      erro: \"Duração não encontrada\",\n      log_ffmpeg: output.substring(output.length - 500) // Pega o final do log onde fica o tempo\n    }\n  }];\n\n} catch (e) {\n  return [{ json: { erro: \"Falha Geral\", mensagem: e.message } }];\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
