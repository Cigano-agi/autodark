      "parameters": {
        "jsCode": "function sanitize(str) {\n  return str\n    .replace(/[\"']/g, '')\n    .normalize(\"NFD\")\n    .replace(/[\\u0300-\\u036f]/g, \"\")\n    .replace(/[^a-zA-Z0-9-_]/g, \"-\")\n    .replace(/-+/g, \"-\")\n    .toLowerCase()\n    .trim();\n}\n\n\n// ============================\n// DICIONÁRIO FONÉTICO DINÂMICO\n// ============================\n\nconst phonemeDict = {\n\n  \"Moisés\": {\n    ipa: \"mo.iˈzɛjs\",\n    alias: \"Moizés\"\n  },\n\n  \"Abraão\": {\n    ipa: \"abɾaˈɐ̃w̃\",\n    alias: \"Abraão\"\n  },\n\n  \"Isaías\": {\n    ipa: \"izaˈi.as\",\n    alias: \"Isaías\"\n  },\n\n  \"Noé\": {\n    ipa: \"noˈɛ\",\n    alias: \"Noé\"\n  },\n\n  \"Jesus\": {\n    ipa: \"ʒeˈzus\",\n    alias: \"Jezus\"\n  }\n\n};\n\n\n// ============================\n// FUNÇÃO QUE APLICA FONEMAS\n// ============================\n\nfunction applyPhonemes(text) {\n\n  for (const word in phonemeDict) {\n\n    const { ipa, alias } = phonemeDict[word];\n\n    const regex = new RegExp(`\\\\b${word}\\\\b`, \"g\");\n\n    // usa phoneme (mais preciso)\n    text = text.replace(\n      regex,\n      `<phoneme alphabet=\"ipa\" ph=\"${ipa}\">${word}</phoneme>`\n    );\n\n    // fallback opcional (se quiser usar alias em vez de IPA)\n    // text = text.replace(regex, `<sub alias=\"${alias}\">${word}</sub>`);\n\n  }\n\n  return text;\n}\n\n\n// ============================\n// LIMPEZA DO TEXTO ORIGINAL\n// ============================\n\nlet rawText = $json.script\n  .replace(/[\"']/g, '')\n  .replace(/\\n+/g, ' ')\n  .trim();\n\n\n// ============================\n// APLICA CORREÇÃO FONÉTICA\n// ============================\n\nrawText = applyPhonemes(rawText);\n\n\n// ============================\n// DIVISÃO EM FRASES\n// ============================\n\nlet sentences = rawText\n  .split(/(?<=[.!?])\\s+(?=[A-ZÀ-Ú])/)\n  .filter(s => s.trim() !== '');\n \n\nlet ssmlText = '';\n\nif (sentences.length > 1) {\n\n  const lastSentence = sentences.pop().trim();\n\n  const body = sentences\n    .map(s => `${s.trim()}.<break time=\"300ms\"/>`)\n    .join(' ');\n\n  ssmlText = `${body} <break time=\"300ms\"/> ${lastSentence}.`;\n\n} else {\n\n  ssmlText = rawText.endsWith('.') ? rawText : rawText + '.';\n\n}\n\n\n// ============================\n// SSML FINAL COM PROSODY\n// ============================\n\nconst ssml = `\n<speak>\n    ${ssmlText}\n</speak>\n`;\n\n\n// ============================\n// STORAGE CONFIG\n// ============================\n\nconst id = $json.id;\nconst nicho = $json.nicho || 'geral';\n\nconst safeNicho = sanitize(nicho);\n\nconst filename = `audio_${id}.mp3`;\nconst storageKey = `tts/${safeNicho}/${filename}`;\n\nreturn [\n  {\n    ssml,\n    id,\n    nicho,\n    safe_nicho: safeNicho,\n    filename,\n    storage_key: storageKey\n  }\n];\n"
      },
