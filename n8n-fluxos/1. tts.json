    {
      "parameters": {
        "jsCode": "// 1. Pega a string SRT que veio da OpenAI\nlet srt = $input.item.json.data;\n\n// --- AJUSTES DE ESTÉTICA ---\n\n// A. Une o diálogo do \"Levanta-te\" com a narração seguinte (Blocos 3 e 4)\nsrt = srt.replace(/— Levanta-te!\\n\\n\\d+\\n00:00:10,420 --> 00:00:16,860\\n— disse/g, \"— Levanta-te! — disse\");\n\n// B. Une o CTA para ficar em um bloco só (Blocos 9 e 10)\n// Isso garante que o \"Se inscreva\" apareça junto com a pergunta\nsrt = srt.replace(/Quer mensagens como essas todos os dias\\?\\n\\n\\d+\\n00:00:39,740 --> 00:00:40,860\\nSe inscreva no canal!/g, \"Quer mensagens como essas todos os dias?\\nSe inscreva no canal!\");\n\n// C. Limpa espaços duplos ou quebras de linha triplas que a OpenAI às vezes manda\nsrt = srt.trim() + \"\\n\\n\";\n\n// 2. Corrige a numeração (caso a gente tenha unido blocos, a contagem muda)\nlet lines = srt.split('\\n');\nlet newSrt = \"\";\nlet counter = 1;\n\nfor (let i = 0; i < lines.length; i++) {\n    if (lines[i].match(/^\\d+$/)) { // Se a linha for só um número\n        newSrt += counter + \"\\n\";\n        counter++;\n    } else {\n        newSrt += lines[i] + \"\\n\";\n    }\n}\n\nreturn { srt: newSrt };"
      },
