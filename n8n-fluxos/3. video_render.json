      "parameters": {
        "jsCode": "const fs = require(\"fs\");\nconst path = require(\"path\");\n\nconst videoId = $json.id.toString();\n\nif (!videoId) {\n  throw new Error(\"videoId não encontrado no payload\");\n}\n\nconst baseDir = \"/home/node/.n8n/render/temp\";\nconst videoDir = path.join(baseDir, videoId);\nconst payloadPath = path.join(videoDir, \"payload.json\");\n\n// segurança: garantir que a pasta existe\nif (!fs.existsSync(videoDir)) {\n  throw new Error(`Diretório do vídeo não encontrado: ${videoDir}`);\n}\n\n// salvar payload\nfs.writeFileSync(\n  payloadPath,\n  JSON.stringify($json, null, 2),\n  \"utf-8\"\n);\n\nreturn [\n  {\n    json: {\n      ...$json,\n      payloadPath,\n      videoDir\n    }\n  }\n];"
      },
