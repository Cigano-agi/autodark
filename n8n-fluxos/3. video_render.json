      "parameters": {
        "jsCode": "// Acessa o stdout do nó anterior\nconst stdoutRaw = $input.item.json.stdout;\n\ntry {\n  // Transforma a string do stdout em um objeto JSON real\n  const result = JSON.parse(stdoutRaw);\n\n  // Retorna os dados limpos para os próximos nós\n  return {\n    videoId: result.videoId,\n    caminho_final: result.path,\n    duracao_segundos: result.duration_seconds,\n    duracao_arredondada: Math.round(result.duration_seconds),\n    total_cenas: result.scenes_count\n  };\n} catch (error) {\n  // Caso o stdout não seja um JSON válido (erro no script anterior)\n  return {\n    erro: \"Falha ao processar JSON do stdout\",\n    raw: stdoutRaw\n  };\n}"
      },
